<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence version="3.0" xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="Lab05JpaHibernate" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>org.example.transportadora.model.CategoriaFrete</class>
        <class>org.example.transportadora.model.Cidade</class>
        <class>org.example.transportadora.model.Cliente</class>
        <class>org.example.transportadora.model.Dependente</class>
        <class>org.example.transportadora.model.Distancia</class>
        <class>org.example.transportadora.model.Filial</class>
        <class>org.example.transportadora.model.Frete</class>
        <class>org.example.transportadora.model.Funcionario</class>
        <class>org.example.transportadora.model.ItemFrete</class>
        <class>org.example.transportadora.model.StatusFrete</class>
        <class>org.example.transportadora.model.PessoaFisica</class>
        <class>org.example.transportadora.model.TipoVeiculo</class>
        <class>org.example.transportadora.model.Veiculo</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver"
                      value="com.mysql.cj.jdbc.Driver" />
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:mysql://localhost:3306/lab05_jpa_hibernate" />
            <property name="jakarta.persistence.jdbc.user"
                      value="root" />
            <property name="jakarta.persistence.jdbc.password"
                      value="root" />
            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.MySQLDialect" />
            <property name="hibernate.show_sql"
                      value="true" />
            <property name="hibernate.format_sql"
                      value="true" />
            <property name="hibernate.hbm2ddl.auto"
                      value="create" />
        </properties>
    </persistence-unit>
</persistence>